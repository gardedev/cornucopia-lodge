{"id":1211,"date":"2019-09-26T12:47:30","date_gmt":"2019-09-26T12:47:30","guid":{"rendered":"https:\/\/musea.qodeinteractive.com\/?page_id=1211"},"modified":"2025-03-10T20:44:58","modified_gmt":"2025-03-10T20:44:58","slug":"our-history","status":"publish","type":"page","link":"https:\/\/cornucopialodge563.com\/our-history\/","title":{"rendered":"Our History"},"content":{"rendered":"<div class=\"wpb-content-wrapper\"><p style=\"text-align: left;\">[vc_row row_content_width=&#8221;grid&#8221; css=&#8221;.vc_custom_1572271648370{padding-top: 147px !important;padding-bottom: 8px !important;}&#8221;][vc_column offset=&#8221;vc_col-lg-offset-1 vc_col-lg-10 vc_col-md-offset-0 vc_col-md-12 vc_col-sm-offset-0 vc_col-xs-12&#8243;]<div class=\"eltdf-section-title-holder   eltdf-st-decorative-line\" style=\"text-align: center\">\n\t<div class=\"eltdf-st-inner\">\n                    <span class=\"eltdf-st-caption\" style=\"color: #c9ab81;margin: 0 0 6px 0\">\n                <span class=\"eltdf-st-caption-inner\" >About Cornucopia Lodge<\/span>\n            <\/span>\n        \t\t\t\t\t<h2 class=\"eltdf-st-title\" >\n    <span class=\"eltdf-st-title-inner\"><span class=\"eltdf-st-side-line-left\" ><\/span>Timeline<span class=\"eltdf-st-side-line-right\" ><\/span><\/span>\n\t\t\t<\/h2>\n\t\t\t\t\t\t\t<p class=\"eltdf-st-text\" style=\"font-size: 19px;line-height: 28px;margin: 13px 0 0 0\">\n\t\t\t\tDiscover the journey of Cornucopia Lodge #563 \u2014 from its founding roots to its growth as a pillar of Freemasonry in Queens, New York.\nThis timeline captures the key moments that shaped our legacy and continue to guide our future.\t\t\t<\/p>\n\t\t\t\t\t<\/div>\n<\/div>[\/vc_column][\/vc_row][vc_row content_placement=&#8221;middle&#8221; row_content_width=&#8221;grid&#8221; el_class=&#8221;eltdf-workflow-custom-alignment&#8221;][vc_column]<div class=\"eltdf-elements-holder   eltdf-one-column  eltdf-responsive-mode-768 eltdf-one-column-alignment-center\" ><div class=\"eltdf-eh-item    \"  data-item-class=\"eltdf-eh-custom-8033\" data-1400-1600=\"0 0 160px 0\" data-1025-1399=\"0 0 160px 0\" data-769-1024=\"0 0 60px 0\" data-681-768=\"0 0 60px 0\" data-680=\"0 0 60px 0\">\n\t<div class=\"eltdf-eh-item-inner\">\n\t\t<div class=\"eltdf-eh-item-content eltdf-eh-custom-8033\" style=\"padding: 0 0 160px 0\">\n\t\t\t<div class=\"eltdf-workflow eltdf-workflow-animate\">\n    <span class=\"alt-line\"><\/span>\n    <span class=\"main-line\" style=\"background-color:#4e4e4e;\"><\/span>\n    <div class=\"eltdf-workflow-item\">\n    <span class=\"line\" style=\"\"><\/span>\n    <div class=\"eltdf-workflow-item-inner\">\n        <div class=\"eltdf-workflow-image\">\n            <img loading=\"lazy\" decoding=\"async\" width=\"529\" height=\"594\" src=\"https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/01\/old-flushing.jpg\" class=\"attachment-full size-full\" alt=\"\" srcset=\"https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/01\/old-flushing.jpg 529w, https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/01\/old-flushing-267x300.jpg 267w\" sizes=\"auto, (max-width: 529px) 100vw, 529px\" \/>        <\/div>\n        <div class=\"eltdf-workflow-text\">\n            <span class=\"circle\" style=\"border-color:#4e4e4e;background-color:#4e4e4e;\"><\/span>\n            <span class=\"circle-line\" style=\"background-color:#4e4e4e;\"><\/span>\n                            <div class=\"year\">September 12th, 1864<\/div>\n                        <div class=\"eltdf-workflow-title-text-holder\">\n                                    <div class=\"year-responsive\">September 12th, 1864<\/div>\n                                                    <span class=\"eltdf-workflow-caption\">Dispensation Issued<\/span>\n                                                    <h2>The Beginning<\/h2>\n                                                    <span class=\"text\">A century ago, when the Civil War was being fought to its climax, the cost in men, materials and money was appalling, the reelection of President Lincoln was uncertain, the cost of living was high, and the years of war had brought many doubts and differences to the men of the North.<br \/>\nIn that time of perplexity, members of the Craft living in and near Flushing Village, imbued with a love of Masonry, filled with Courage and Vision, and confident of their Destiny, set about forming a Masonic Lodge. On September 12th, 1864, a Dispensation was issued to Cornucopia Lodge, the first Masonic organization to be formed in the Village of Flushing.<br \/>\nThe Dispensation was signed by Most Worshipful Clinton F. Paige, Grand Master, and attested by James M. Austin as Grand Secretary.<\/span>\n                            <\/div>\n        <\/div>\n    <\/div>\n<\/div>\n<div class=\"eltdf-workflow-item\">\n    <span class=\"line\" style=\"\"><\/span>\n    <div class=\"eltdf-workflow-item-inner\">\n        <div class=\"eltdf-workflow-image\">\n            <img loading=\"lazy\" decoding=\"async\" width=\"1258\" height=\"711\" src=\"https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/01\/old-corn-group.jpg\" class=\"attachment-full size-full\" alt=\"\" srcset=\"https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/01\/old-corn-group.jpg 1258w, https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/01\/old-corn-group-300x170.jpg 300w, https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/01\/old-corn-group-1024x579.jpg 1024w, https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/01\/old-corn-group-768x434.jpg 768w\" sizes=\"auto, (max-width: 1258px) 100vw, 1258px\" \/>        <\/div>\n        <div class=\"eltdf-workflow-text\">\n            <span class=\"circle\" style=\"border-color:#4e4e4e;background-color:#4e4e4e;\"><\/span>\n            <span class=\"circle-line\" style=\"background-color:#4e4e4e;\"><\/span>\n                            <div class=\"year\">September 14th, 1864<\/div>\n                        <div class=\"eltdf-workflow-title-text-holder\">\n                                    <div class=\"year-responsive\">September 14th, 1864<\/div>\n                                                    <span class=\"eltdf-workflow-caption\">The First Communication<\/span>\n                                                    <h2>Day One<\/h2>\n                                                    <span class=\"text\">The first communication U.D., was held on September 14, 1864. The minutes do not disclose where.\nThe By-Laws of Keystone Lodge No. 235 were adopted as the By-Laws to be used by Cornucopia U.D.\nMorton Lodge No. 63 of Hempstead and Jamaica Lodge No. 546, recommended the granting of the Dispensation. R:. W:. Charles W. Willetts, Brooklyn, was District Deputy for Kings, Queens and Suffolk Counties at the time.<\/span>\n                            <\/div>\n        <\/div>\n    <\/div>\n<\/div>\n<div class=\"eltdf-workflow-item\">\n    <span class=\"line\" style=\"\"><\/span>\n    <div class=\"eltdf-workflow-item-inner\">\n        <div class=\"eltdf-workflow-image\">\n            <img loading=\"lazy\" decoding=\"async\" width=\"1336\" height=\"842\" src=\"https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/02\/another-old-lodge-pic.jpg\" class=\"attachment-full size-full\" alt=\"\" srcset=\"https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/02\/another-old-lodge-pic.jpg 1336w, https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/02\/another-old-lodge-pic-300x189.jpg 300w, https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/02\/another-old-lodge-pic-1024x645.jpg 1024w, https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/02\/another-old-lodge-pic-768x484.jpg 768w\" sizes=\"auto, (max-width: 1336px) 100vw, 1336px\" \/>        <\/div>\n        <div class=\"eltdf-workflow-text\">\n            <span class=\"circle\" style=\"border-color:#4e4e4e;background-color:#4e4e4e;\"><\/span>\n            <span class=\"circle-line\" style=\"background-color:#4e4e4e;\"><\/span>\n                            <div class=\"year\">1908 - 1990<\/div>\n                        <div class=\"eltdf-workflow-title-text-holder\">\n                                    <div class=\"year-responsive\">1908 - 1990<\/div>\n                                                    <span class=\"eltdf-workflow-caption\">The Legacy of The Temple<\/span>\n                                                    <h2>The Edifice<\/h2>\n                                                    <span class=\"text\">On June 13, 1908, Cornucopia Lodge #563 laid the cornerstone for its Masonic Temple at the corner of Northern Boulevard and Union Street in Flushing. This multi-story brick structure became the first of its kind in the area and was dedicated later that year on November 26 in a ceremonial event led by Grand Master Sawyer, who was presented with an ivory gavel by the Lodge. The temple, built at a cost of $40,000, became a gathering place for countless social events and Masonic rituals, strengthening the lodge's ties to the community. R.B. Thomas, then Commissioner of Education and a prominent figure in the development of Flushing High School, played a key role in overseeing the temple's construction despite never attending college himself.<br \/>\nFor over eight decades, the Cornucopia Lodge Temple was a cornerstone of Flushing's cultural and architectural heritage. However, in 1990, rising real estate taxes forced the Lodge to sell the building. Occupied by the Siloam Reformed Church until its final days, the temple faced demolition in 2018 to make way for a modern mixed-use development. Although attempts to preserve the site failed, the memories of the historic lodge remain vivid in the hearts of many, representing a chapter of resilience and brotherhood in Flushing\u2019s evolving landscape.<\/span>\n                            <\/div>\n        <\/div>\n    <\/div>\n<\/div>\n<div class=\"eltdf-workflow-item\">\n    <span class=\"line\" style=\"\"><\/span>\n    <div class=\"eltdf-workflow-item-inner\">\n        <div class=\"eltdf-workflow-image\">\n            <img loading=\"lazy\" decoding=\"async\" width=\"956\" height=\"845\" src=\"https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/02\/famous-members-2.jpg\" class=\"attachment-full size-full\" alt=\"\" srcset=\"https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/02\/famous-members-2.jpg 956w, https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/02\/famous-members-2-300x265.jpg 300w, https:\/\/cornucopialodge563.com\/wp-content\/uploads\/2025\/02\/famous-members-2-768x679.jpg 768w\" sizes=\"auto, (max-width: 956px) 100vw, 956px\" \/>        <\/div>\n        <div class=\"eltdf-workflow-text\">\n            <span class=\"circle\" style=\"border-color:#4e4e4e;background-color:#4e4e4e;\"><\/span>\n            <span class=\"circle-line\" style=\"background-color:#4e4e4e;\"><\/span>\n                            <div class=\"year\">Historic to Present<\/div>\n                        <div class=\"eltdf-workflow-title-text-holder\">\n                                    <div class=\"year-responsive\">Historic to Present<\/div>\n                                                    <span class=\"eltdf-workflow-caption\">Continuing Excellence<\/span>\n                                                    <h2>Notable Members<\/h2>\n                                                    <span class=\"text\">Cornucopia Lodge No. 563 has a rich history of members who have distinguished themselves across various fields, including government service, the arts, and sciences. While historical records may not capture all notable Craftsmen, our list of Past Masters highlights individuals who have significantly impacted Flushing, New York City, and the nation.<br \/>\nBrother Marshall P. Wilder was a celebrated actor and elocutionist, known for his contributions to the performing arts. Brother Daniel Carter Beard, an author and illustrator, founded the Boy Scouts of America, instilling Masonic principles into the organization. He was initiated in Mariner's Lodge No. 67 in New York City and later affiliated with Cornucopia Lodge No. 563 in Flushing.<br \/>\nBrother John W. Crawford played a pivotal role in the construction and financing of the Y.M.C.A. building in Flushing, leaving a lasting legacy in the community. Right Worshipful William Rasquin Jr. earned acclaim in both Masonry and the utility sector, while Brother Maynard Spear also gained recognition in the same field. Brother Robert Wilkes made significant contributions to journalism, and Worshipful Brother Harry Gelwicks excelled in news and advertising.<br \/>\nWorshipful William T. James and Brother Edgar Bowne distinguished themselves in banking, and Worshipful George W. Pople was known for his various civic activities. Right Worshipful George U. Harvey served as the Queens Borough President, exemplifying the Lodge's influence in public service.<br \/>\nToday, Cornucopia Lodge continues to be home to distinguished members actively serving in government and other prominent fields, upholding the legacy of excellence established by our predecessors.<\/span>\n                            <\/div>\n        <\/div>\n    <\/div>\n<\/div>\n    <div class=\"eltdf-workflow-item eltdf-wi-hidden\">\n        <div class=\"eltdf-workflow-item-inner\">\n            <div class=\"eltdf-workflow-text\">\n                <span class=\"circle\"><\/span>\n            <\/div>\n        <\/div>\n    <\/div>\n<\/div>\t\t<\/div>\n\t<\/div>\n<\/div><\/div>[\/vc_column][\/vc_row]<\/p>\n<\/div>","protected":false},"excerpt":{"rendered":"<p>[vc_row row_content_width=&#8221;grid&#8221; css=&#8221;.vc_custom_1572271648370{padding-top: 147px !important;padding-bottom: 8px !important;}&#8221;][vc_column offset=&#8221;vc_col-lg-offset-1 vc_col-lg-10 vc_col-md-offset-0 vc_col-md-12 vc_col-sm-offset-0 vc_col-xs-12&#8243;][\/vc_column][\/vc_row][vc_row content_placement=&#8221;middle&#8221; row_content_width=&#8221;grid&#8221; el_class=&#8221;eltdf-workflow-custom-alignment&#8221;][vc_column][\/vc_column][\/vc_row]<\/p>\n","protected":false},"author":1,"featured_media":0,"parent":0,"menu_order":0,"comment_status":"closed","ping_status":"closed","template":"full-width.php","meta":{"footnotes":""},"class_list":["post-1211","page","type-page","status-publish","hentry"],"_links":{"self":[{"href":"https:\/\/cornucopialodge563.com\/wp-json\/wp\/v2\/pages\/1211","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/cornucopialodge563.com\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/cornucopialodge563.com\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"https:\/\/cornucopialodge563.com\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/cornucopialodge563.com\/wp-json\/wp\/v2\/comments?post=1211"}],"version-history":[{"count":22,"href":"https:\/\/cornucopialodge563.com\/wp-json\/wp\/v2\/pages\/1211\/revisions"}],"predecessor-version":[{"id":2570,"href":"https:\/\/cornucopialodge563.com\/wp-json\/wp\/v2\/pages\/1211\/revisions\/2570"}],"wp:attachment":[{"href":"https:\/\/cornucopialodge563.com\/wp-json\/wp\/v2\/media?parent=1211"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}